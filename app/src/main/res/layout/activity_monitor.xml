<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">
        <TextView android:id="@+id/tvDeviceName"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#00E676" android:textSize="16sp" android:fontFamily="monospace" android:text="DEVICE"/>
        <TextView android:id="@+id/tvStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#00E676" android:textSize="13sp" android:fontFamily="monospace"
            android:text="⬤  CONNECTING..."/>
    </LinearLayout>

    <!-- Video Feed -->
    <ImageView android:id="@+id/ivVideo"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:scaleType="fitCenter" android:background="#111111"/>

    <!-- Controls row -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="8dp" android:background="#111111">

        <ImageButton android:id="@+id/btnRecord"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <TextView android:id="@+id/tvRecTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FF3D3D" android:textSize="13sp" android:fontFamily="monospace"
            android:paddingStart="6dp" android:visibility="gone" android:text="⏺ 00:00"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton android:id="@+id/btnScreenshot"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <ImageButton android:id="@+id/btnVideoToggle"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_view"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <ImageButton android:id="@+id/btnAudioToggle"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <ImageButton android:id="@+id/btnSwitchCam"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <Button android:id="@+id/btnEq"
            android:layout_width="44dp" android:layout_height="44dp"
            android:text="EQ" android:textColor="#00E676" android:textSize="11sp"
            android:fontFamily="monospace" android:background="#1A1A1A" android:padding="4dp"/>
    </LinearLayout>

    <!-- 10-band Equalizer panel -->
    <LinearLayout
        android:id="@+id/layoutEq"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111111"
        android:visibility="gone">

        <!-- Waveform visualizer -->
        <com.lynxeye.AudioVisualizerView
            android:id="@+id/visualizer"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#111111"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#111111">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Band 0: 32Hz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand0" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 1: 64Hz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand1" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 2: 125Hz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand2" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 3: 250Hz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand3" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 4: 500Hz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand4" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 5: 1kHz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand5" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 6: 2kHz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand6" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 7: 4kHz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand7" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 8: 8kHz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand8" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

            <!-- Band 9: 16kHz -->
            <LinearLayout android:layout_width="52dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
                <SeekBar android:id="@+id/seekBand9" android:layout_width="180dp" android:layout_height="36dp" android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                <TextView android:id="@+id/tvBand9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00E676" android:textSize="9sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
                <TextView android:id="@+id/tvGain9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#555555" android:textSize="8sp" android:fontFamily="monospace" android:text="0dB"/>
            </LinearLayout>

        </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>
