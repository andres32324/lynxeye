<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬤  CONNECTING..."
                android:textSize="11sp"
                android:textColor="#FFAA00"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRecTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏺ 00:00"
            android:textSize="11sp"
            android:textColor="#FF3D3D"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginEnd="8dp"/>
    </LinearLayout>

    <!-- Video Feed -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="#0D1A0D">

        <ImageView
            android:id="@+id/ivVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE FEED"
            android:textSize="9sp"
            android:textColor="#1A4D1A"
            android:fontFamily="monospace"
            android:padding="6dp"
            android:layout_gravity="top|start"/>

        <ImageButton
            android:id="@+id/btnFullscreen"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_zoom"
            android:background="@android:color/transparent"
            android:tint="#00E676"
            android:layout_gravity="top|end"
            android:padding="4dp"/>

        <ImageButton
            android:id="@+id/btnSwitchCam"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@android:color/transparent"
            android:tint="#00E676"
            android:layout_gravity="bottom|end"
            android:padding="4dp"/>
    </FrameLayout>

    <!-- Scrollable controls -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AUDIO CONTROL section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUDIO CONTROL"
                android:textSize="11sp"
                android:textColor="#00E676"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp"/>

            <!-- Volume -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔊" android:textSize="16sp" android:layout_marginEnd="8dp"/>
                <SeekBar
                    android:id="@+id/seekVolume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="#00E676"
                    android:thumbTint="#00E676"/>
            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/card_dark" android:padding="16dp" android:layout_marginEnd="8dp">
                    <ImageButton
                        android:id="@+id/btnRecord"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="@android:color/transparent"
                        android:tint="#FF3D3D"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REC" android:textSize="10sp" android:textColor="#FF3D3D" android:fontFamily="monospace" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/card_dark" android:padding="16dp">
                    <ImageButton
                        android:id="@+id/btnEq"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:background="@android:color/transparent"
                        android:tint="#00E676"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EQ" android:textSize="10sp" android:textColor="#00E676" android:fontFamily="monospace" android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- EQUALIZER panel -->
            <LinearLayout
                android:id="@+id/layoutEq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EQUALIZER" android:textSize="11sp" android:textColor="#00E676" android:fontFamily="monospace" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <SeekBar android:id="@+id/seekBand0" android:layout_width="match_parent" android:layout_height="wrap_content" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                        <TextView android:id="@+id/tvBand0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60Hz" android:textSize="9sp" android:textColor="#555555" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <SeekBar android:id="@+id/seekBand1" android:layout_width="match_parent" android:layout_height="wrap_content" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                        <TextView android:id="@+id/tvBand1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="230Hz" android:textSize="9sp" android:textColor="#555555" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <SeekBar android:id="@+id/seekBand2" android:layout_width="match_parent" android:layout_height="wrap_content" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                        <TextView android:id="@+id/tvBand2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="910Hz" android:textSize="9sp" android:textColor="#555555" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <SeekBar android:id="@+id/seekBand3" android:layout_width="match_parent" android:layout_height="wrap_content" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                        <TextView android:id="@+id/tvBand3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3.6kHz" android:textSize="9sp" android:textColor="#555555" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <SeekBar android:id="@+id/seekBand4" android:layout_width="match_parent" android:layout_height="wrap_content" android:progressTint="#00E676" android:thumbTint="#00E676"/>
                        <TextView android:id="@+id/tvBand4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14kHz" android:textSize="9sp" android:textColor="#555555" android:fontFamily="monospace"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
