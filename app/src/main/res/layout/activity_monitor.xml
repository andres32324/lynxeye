<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">
        <TextView android:id="@+id/tvDeviceName"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#00E676" android:textSize="16sp" android:fontFamily="monospace" android:text="DEVICE"/>
        <TextView android:id="@+id/tvStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#00E676" android:textSize="13sp" android:fontFamily="monospace"
            android:text="⬤  CONNECTING..."/>
    </LinearLayout>

    <!-- Video Feed -->
    <ImageView android:id="@+id/ivVideo"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:scaleType="fitCenter" android:background="#111111"/>

    <!-- Controls row -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="8dp" android:background="#111111">

        <ImageButton android:id="@+id/btnRecord"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <TextView android:id="@+id/tvRecTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FF3D3D" android:textSize="13sp" android:fontFamily="monospace"
            android:paddingStart="6dp" android:visibility="gone" android:text="⏺ 00:00"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <SeekBar android:id="@+id/seekVolume"
            android:layout_width="90dp" android:layout_height="wrap_content"
            android:progressTint="#00E676" android:thumbTint="#00E676"/>

        <View android:layout_width="6dp" android:layout_height="1dp"/>

        <ImageButton android:id="@+id/btnScreenshot"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <ImageButton android:id="@+id/btnSwitchCam"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="#1A1A1A" android:tint="#00E676" android:padding="8dp"/>

        <Button android:id="@+id/btnEq"
            android:layout_width="44dp" android:layout_height="44dp"
            android:text="EQ" android:textColor="#00E676" android:textSize="11sp"
            android:fontFamily="monospace" android:background="#1A1A1A" android:padding="4dp"/>
    </LinearLayout>

    <!-- Equalizer panel -->
    <LinearLayout android:id="@+id/layoutEq"
        android:layout_width="match_parent" android:layout_height="220dp"
        android:orientation="horizontal" android:gravity="center"
        android:background="#111111" android:paddingTop="12dp" android:paddingBottom="12dp"
        android:visibility="gone">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <SeekBar android:id="@+id/seekBand0" android:layout_width="180dp" android:layout_height="40dp"
                android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
            <TextView android:id="@+id/tvBand0" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00E676" android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <SeekBar android:id="@+id/seekBand1" android:layout_width="180dp" android:layout_height="40dp"
                android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
            <TextView android:id="@+id/tvBand1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00E676" android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <SeekBar android:id="@+id/seekBand2" android:layout_width="180dp" android:layout_height="40dp"
                android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
            <TextView android:id="@+id/tvBand2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00E676" android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <SeekBar android:id="@+id/seekBand3" android:layout_width="180dp" android:layout_height="40dp"
                android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
            <TextView android:id="@+id/tvBand3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00E676" android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <SeekBar android:id="@+id/seekBand4" android:layout_width="180dp" android:layout_height="40dp"
                android:rotation="270" android:progressTint="#00E676" android:thumbTint="#00E676"/>
            <TextView android:id="@+id/tvBand4" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00E676" android:textSize="10sp" android:fontFamily="monospace" android:layout_marginTop="16dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
